import json

def parse_explain_json(explain_output: str) -> dict:
    """
    MySQL EXPLAIN FORMAT=JSON 결과를 파싱하여 주요 지표 추출
    """
    try:
        # JSON 문자열을 파이썬 딕셔너리로 변환
        parsed_data = json.loads(explain_output)
        
        # 기본 스캔 방식 (Access Type) 및 예상 행(Rows) 수 추출
        query_block = parsed_data.get('query_block', {})
        table_info = query_block.get('table', {})

        # 통합 시 참고할 핵심 데이터 파싱
        access_type = table_info.get('access_type', 'UNKNOWN') # 예: ALL(풀스캔), ref 등
        rows_examined = table_info.get('rows', 0)

        return {
            "status": "success",
            "access_type": access_type, 
            "rows_examined": rows_examined
        }

    except json.JSONDecodeError:
        return {
            "status": "error",
            "message": "유효한 JSON 형식이 아닙니다."
        }
    except Exception as e:
        return {
            "status": "error",
            "message": f"파싱 중 오류 발생: {str(e)}"
        }
